@model quizportal.Models.ViewModels.QuizAttemptStartViewModel
@{
    ViewData["Title"] = "Start Quiz";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">@Model.Title</h2>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-2">
                        @(string.IsNullOrWhiteSpace(Model.SubjectName) ? "Get ready to attempt this quiz." : $"Subject: {Model.SubjectName}")
                    </p>
                    @if (!string.IsNullOrWhiteSpace(Model.StudentName))
                    {
                        <p class="mb-4">Attempting as <strong>@Model.StudentName</strong></p>
                    }

                    <div class="row g-3 mb-4">
                        <div class="col-sm-4">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="text-muted small text-uppercase">Questions</div>
                                <div class="fs-4 fw-bold">@Model.QuestionCount</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="text-muted small text-uppercase">Total Marks</div>
                                <div class="fs-4 fw-bold">@Model.TotalMarks</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="text-muted small text-uppercase">Time Limit</div>
                                <div class="fs-4 fw-bold">@Model.TimeLimitMinutes min</div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Start" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="QuizId" />

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Start Quiz</button>
                            <a asp-controller="QuizAttempt" asp-action="Index" class="btn btn-outline-secondary btn-lg">Back to Attempt Quiz</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

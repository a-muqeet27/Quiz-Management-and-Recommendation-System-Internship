@model quizportal.Models.ViewModels.QuizAttemptTakeViewModel
@{
    ViewData["Title"] = "Attempt Quiz";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h2 class="mb-1">@Model.QuizTitle</h2>
            <p class="text-muted mb-0">Answer all questions and submit when finished.</p>
        </div>
        @if (Model.TimeLimitMinutes > 0)
        {
            <span class="badge bg-secondary fs-6">Time limit: @Model.TimeLimitMinutes min</span>
        }
    </div>

    <form asp-action="Submit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="QuizAttemptId" value="@Model.QuizAttemptId" />

        @for (var i = 0; i < Model.Questions.Count; i++)
        {
            var question = Model.Questions[i];
            var isSingleCorrect = question.QuestionType == 1;

            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <h5 class="mb-0">Q@(i + 1). @question.QuestionStatement</h5>
                        <span class="badge bg-light text-dark border">@question.Score mark@(question.Score == 1 ? "" : "s")</span>
                    </div>

                    <input type="hidden" name="Answers[@i].QuestionId" value="@question.QuestionId" />

                    <div class="list-group">
                        @foreach (var choice in question.Choices)
                        {
                            <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 mb-0">
                                @if (isSingleCorrect)
                                {
                                    <input class="form-check-input mt-0"
                                           type="radio"
                                           name="Answers[@i].SelectedChoiceIds"
                                           value="@choice.ChoiceId" />
                                }
                                else
                                {
                                    <input class="form-check-input mt-0"
                                           type="checkbox"
                                           name="Answers[@i].SelectedChoiceIds"
                                           value="@choice.ChoiceId" />
                                }
                                <span>@choice.ChoiceText</span>
                            </label>
                        }
                    </div>

                    <small class="text-muted d-block mt-2">
                        @(isSingleCorrect ? "Select one answer." : "Select all correct answers.")
                    </small>
                </div>
            </div>
        }

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-success btn-lg">Save Quiz</button>
        </div>
    </form>
</div>

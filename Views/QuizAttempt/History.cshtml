@model IEnumerable<quizportal.Models.ViewModels.QuizAttemptHistoryViewModel>
@{
    ViewData["Title"] = "Saved Attempts";
    var studentName = ViewBag.StudentName as string;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="mb-1">My Saved Attempts</h2>
            @if (!string.IsNullOrWhiteSpace(studentName))
            {
                <p class="text-muted mb-0">Showing attempts for <strong>@studentName</strong></p>
            }
            else
            {
                <p class="text-muted mb-0">Start a quiz with your name to save and view your attempts here.</p>
            }
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Attempt Quiz</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm text-center p-5">
            <h4>No saved attempts yet</h4>
            <p class="text-muted mb-3">Complete a quiz to save your attempt here. Your answers will be stored separately from the correct/wrong review.</p>
            <a asp-action="Index" class="btn btn-success">Attempt a Quiz</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Quiz</th>
                        <th>Score</th>
                        <th>Percentage</th>
                        <th width="240">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var attempt in Model)
                    {
                        <tr>
                            <td>@attempt.AttemptDate.ToLocalTime().ToString("g")</td>
                            <td class="text-start"><strong>@attempt.QuizTitle</strong></td>
                            <td>@attempt.ObtainedMarks / @attempt.TotalMarks</td>
                            <td>@attempt.QuizPercentage.ToString("0.##")%</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@attempt.QuizAttemptId" class="btn btn-primary btn-sm">View Attempt</a>
                                <a asp-action="Review" asp-route-id="@attempt.QuizAttemptId" class="btn btn-outline-info btn-sm">Review</a>
                                <a asp-action="Start" asp-route-id="@attempt.QuizId" class="btn btn-success btn-sm">Re-attempt</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

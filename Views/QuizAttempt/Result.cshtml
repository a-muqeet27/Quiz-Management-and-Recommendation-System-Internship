@model quizportal.Models.ViewModels.QuizAttemptResultViewModel
@{
    ViewData["Title"] = "Quiz Result";
    var scoreClass = Model.QuizPercentage >= 70 ? "success" : Model.QuizPercentage >= 50 ? "warning" : "danger";
}

<div class="container mt-4 mb-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-@scoreClass text-white text-center py-4">
                    <h2 class="mb-1">@Model.QuizTitle</h2>
                    <p class="mb-0 opacity-75">Quiz completed by @Model.StudentName</p>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="text-muted text-uppercase small mb-2">Your Score</p>
                    <h1 class="display-3 fw-bold text-@scoreClass mb-1">
                        @Model.ObtainedMarks.ToString("0.##") / @Model.TotalMarks.ToString("0.##")
                    </h1>
                    <p class="fs-4 mb-4">@Model.QuizPercentage.ToString("0.##")%</p>

                    <span class="badge bg-@scoreClass fs-6 mb-4">@Model.PerformanceLabel</span>

                    <div class="row g-3 text-start">
                        <div class="col-sm-4">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="text-muted small text-uppercase">Correct</div>
                                <div class="fs-4 fw-bold text-success">@Model.CorrectAnswers</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="text-muted small text-uppercase">Wrong</div>
                                <div class="fs-4 fw-bold text-danger">@Model.WrongAnswers</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="text-muted small text-uppercase">Unattempted</div>
                                <div class="fs-4 fw-bold text-secondary">@Model.Unattempted</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
                        <a asp-controller="QuizAttempt" asp-action="Index" class="btn btn-primary">Back to Attempt Quiz</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "Home";
    var isAdmin = User.IsInRole(quizportal.Models.AppRoles.AdminName);
    var isTeacher = User.IsInRole(quizportal.Models.AppRoles.TeacherName);
    var isStudent = User.IsInRole(quizportal.Models.AppRoles.StudentName);
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h1 class="display-4 fw-bold">Quiz Portal</h1>
        @if (isAdmin)
        {
            <p class="lead">Admin Portal</p>
        }
        else if (isTeacher)
        {
            <p class="lead">Teacher Dashboard</p>
        }
        else if (isStudent)
        {
            <p class="lead">Student Dashboard</p>
        }
    </div>

    @if (isAdmin || isTeacher)
    {
        <div class="row justify-content-center">
            <div class="col-md-3 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Subjects</h3>
                        <p>@(isAdmin ? "View and Manage all Subjects" : "Add Subjects for Quizzes")</p>
                        <a asp-controller="Subject" asp-action="Index" class="btn btn-outline-primary">Manage Subjects</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Topics</h3>
                        <p>@(isAdmin ? "View and Manage all Topics" : "Add Topics under a Subject")</p>
                        <a asp-controller="Topic" asp-action="Index" class="btn btn-outline-primary">Manage Topics</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Questions</h3>
                        <p>@(isAdmin ? "View and Manage all Questions" : "Build your Question Bank with Choices")</p>
                        <a asp-controller="Question" asp-action="Index" class="btn btn-outline-primary">Manage Questions</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Quizzes</h3>
                        <p>@(isAdmin ? "View and Manage all Quizzes" : "Build Quizzes from your Question Bank")</p>
                        <a asp-controller="Quiz" asp-action="QuizList" class="btn btn-outline-primary">Manage Quizzes</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (isStudent)
    {
        <div class="row justify-content-center">
            <div class="col-md-4 mb-4">
                <div class="card shadow h-100 border-success">
                    <div class="card-body text-center">
                        <h3>Attempt Quiz</h3>
                        <p>Browse Quizzes and Test your Knowledge</p>
                        <a asp-controller="QuizAttempt" asp-action="Index" class="btn btn-success">Start Quiz</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Quiz Attempts</h3>
                        <p>View your Past Quiz Attempts and Scores</p>
                        <a asp-controller="QuizAttempt" asp-action="History" class="btn btn-outline-primary">View Attempts</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow h-100 border-primary">
                    <div class="card-body text-center">
                        <h3>Questions</h3>
                        <p>Review Questions and Discuss with Teachers and Classmates</p>
                        <a asp-controller="StudentQuestion" asp-action="Index" class="btn btn-outline-primary">Browse Questions</a>
                    </div>
                </div>
            </div>

        </div>
    }
</div>

@{
    ViewData["Title"] = "Home";
    var isTeacher = User.IsInRole(quizportal.Models.AppRoles.TeacherName);
    var isStudent = User.IsInRole(quizportal.Models.AppRoles.StudentName);
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h1 class="display-4 fw-bold">Quiz Portal</h1>
        @if (isTeacher)
        {
            <p class="lead">Teacher Dashboard</p>
        }
        else if (isStudent)
        {
            <p class="lead">Student Dashboard</p>
        }
    </div>

    @if (isTeacher)
    {
        <div class="row justify-content-center">
            <div class="col-md-3 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Subjects</h3>
                        <p>Add subjects for quizzes and topics</p>
                        <a asp-controller="Subject" asp-action="Create" class="btn btn-outline-primary">Create Subject</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Topics</h3>
                        <p>Add topics under a subject</p>
                        <a asp-controller="Topic" asp-action="Create" class="btn btn-outline-primary">Create Topic</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Questions</h3>
                        <p>Build your question bank with choices</p>
                        <a asp-controller="Question" asp-action="Create" class="btn btn-outline-primary">Create Question</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>Quizzes</h3>
                        <p>Build quizzes from your question bank</p>
                        <a asp-controller="Quiz" asp-action="Create" class="btn btn-outline-primary">Create Quiz</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (isStudent)
    {
        <div class="row justify-content-center">
            <div class="col-md-4 mb-4">
                <div class="card shadow h-100 border-success">
                    <div class="card-body text-center">
                        <h3>Attempt Quiz</h3>
                        <p>Browse active quizzes and test your knowledge</p>
                        <a asp-controller="QuizAttempt" asp-action="Index" class="btn btn-success">Start Quiz</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h3>History</h3>
                        <p>View your past quiz attempts and scores</p>
                        <a asp-controller="QuizAttempt" asp-action="History" class="btn btn-outline-primary">View Attempts</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

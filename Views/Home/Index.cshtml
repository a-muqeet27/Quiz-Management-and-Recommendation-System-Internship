@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Quiz Portal</h1>
        <p class="lead">
            Welcome to the Quiz Management System
        </p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <div class="card-body text-center">
                    <h3>Create Quiz</h3>
                    <p>Create a New Quiz for Students</p>
                    <a asp-controller="Quiz" asp-action="Create" class="btn btn-primary">Create Quiz</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <div class="card-body text-center">
                    <h3>View Quizzes</h3>
                    <p>Manage All Created Quizzes</p>
                    <a asp-controller="Quiz" asp-action="QuizList" class="btn btn-success">View Quizzes</a>
                </div>
            </div>
        </div>

    </div>

</div>
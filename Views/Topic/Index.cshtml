@model IEnumerable<quizportal.Models.Topic>
@{
    ViewData["Title"] = "Topics";
    var subjects = ViewBag.Subjects as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<div class="container mt-4 mb-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="mb-1">Topics</h2>
            <p class="text-muted mb-0">Topics belong to a subject and can filter quizzes</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">+ Create Topic</a>
    </div>

    <form method="get" asp-action="Index" class="row g-2 align-items-end mb-4">
        <div class="col-md-5">
            <label class="form-label fw-semibold">Filter by Subject</label>
            <select name="subjectId" class="form-select" onchange="this.form.submit()">
                @foreach (var item in subjects)
                {
                    if (item.Selected)
                    {
                        <option value="@item.Value" selected>@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="card shadow-sm text-center p-5">
            <h4>No topics yet</h4>
            <p class="text-muted">Create a subject first, then add topics under it.</p>
            <div class="d-flex justify-content-center gap-2">
                <a asp-controller="Subject" asp-action="Create" class="btn btn-outline-primary">Create Subject</a>
                <a asp-action="Create" class="btn btn-primary">Create Topic</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Topic</th>
                        <th>Subject</th>
                        <th>Description</th>
                        <th>Created</th>
                        <th width="180">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var topic in Model)
                    {
                        <tr>
                            <td>@topic.TopicId</td>
                            <td class="text-start"><strong>@topic.TopicName</strong></td>
                            <td>@(topic.Subject?.SubjectName ?? "-")</td>
                            <td class="text-start">@(topic.TopicDescription ?? "-")</td>
                            <td>@topic.CreatedDate.ToLocalTime().ToString("g")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@topic.TopicId" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@topic.TopicId" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

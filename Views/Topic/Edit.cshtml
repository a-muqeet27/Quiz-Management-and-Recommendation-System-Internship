@model quizportal.Models.Topic
@{
    ViewData["Title"] = "Edit Topic";
    var subjects = ViewBag.Subjects as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1">Edit Topic</h2>
                    <p class="text-muted mb-0">Update <strong>@Model.TopicName</strong></p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="TopicId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="SubjectId" class="form-label fw-semibold">Subject</label>
                            <select name="SubjectId" id="SubjectId" class="form-select" required>
                                @foreach (var item in subjects)
                                {
                                    if (item.Selected || item.Value == Model.SubjectId.ToString())
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="SubjectId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TopicName" class="form-label fw-semibold">Topic Name</label>
                            <input asp-for="TopicName" class="form-control" maxlength="100" required />
                            <span asp-validation-for="TopicName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TopicDescription" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="TopicDescription" class="form-control" rows="3" maxlength="500"></textarea>
                            <span asp-validation-for="TopicDescription" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Save Changes</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model quizportal.Models.Topic
@{
    ViewData["Title"] = "Create Topic";
    var subjects = ViewBag.Subjects as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var hasSubjects = ViewBag.HasSubjects as bool? ?? false;
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1">Create Topic</h2>
                    <p class="text-muted mb-0">Choose a subject from the dropdown, then add a topic</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>

            @if (!hasSubjects)
            {
                <div class="alert alert-warning">
                    No subjects found.
                    <a asp-controller="Subject" asp-action="Create" class="alert-link">Create a subject</a> first.
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="SubjectId" class="form-label fw-semibold">Subject</label>
                            <select name="SubjectId" id="SubjectId" class="form-select" required>
                                @foreach (var item in subjects)
                                {
                                    if (item.Selected)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="SubjectId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TopicName" class="form-label fw-semibold">Topic Name</label>
                            <input asp-for="TopicName" class="form-control" maxlength="100" placeholder="e.g. Algebra" required />
                            <span asp-validation-for="TopicName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TopicDescription" class="form-label fw-semibold">Description <span class="text-muted fw-normal">(optional)</span></label>
                            <textarea asp-for="TopicDescription" class="form-control" rows="3" maxlength="500" placeholder="Short description of this topic"></textarea>
                            <span asp-validation-for="TopicDescription" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@(!hasSubjects)">Save Topic</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

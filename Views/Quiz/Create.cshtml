@{
    ViewData["Title"] = "Create Quiz";
}

<div class="container mt-5">

    <h2>Create Quiz</h2>

    <form method="post" action="/Quiz/Create">
        <div class="mb-3">
            @Html.AntiForgeryToken()
            <label>Quiz Title</label>
            <input type="text" name="Title" class="form-control" required />
        </div>

        <div class="mb-3">
            <label>Number of Questions</label>
            <input type="number" name="NoOfQuestions" class="form-control" min="1" required />
        </div>


        <div class="mb-3">
            <label>Total Marks</label>
            <input type="number" name="TotalMarks" class="form-control" min="1" required />
        </div>


        <div class="mb-3">
            <label>Time Limit</label>
            <select name="TimeLimit" class="form-select" required>
                <option value="">Select Time</option>
                <option value="5">5 Minutes</option>
                <option value="10">10 Minutes</option>
                <option value="15">15 Minutes</option>
                <option value="20">20 Minutes</option>
                <option value="30">30 Minutes</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Save Quiz</button>
        <a href="/Quiz/QuizList" class="btn btn-secondary">Cancel</a>

    </form>
</div>
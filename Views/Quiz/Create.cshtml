@model quizportal.Models.ViewModels.QuizFormViewModel
@{
    ViewData["Title"] = "Create Quiz";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Create Quiz</h2>
            <p class="text-muted mb-0">Build a new quiz using your database subjects, topics, and question filters.</p>
        </div>
        <a asp-action="QuizList" class="btn btn-outline-secondary">Back to List</a>
    </div>

    <form asp-action="Create" method="post" id="quizForm">
        @Html.AntiForgeryToken()
        <partial name="_QuizFormFields" model="Model" />
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/quiz-form.js" asp-append-version="true"></script>
}

@model quizportal.Models.ViewModels.QuizFormViewModel
@{
    var hasSubjects = ViewBag.HasSubjects as bool? ?? Model.Subjects.Any(s => !string.IsNullOrEmpty(s.Value));
    var isCreate = Model.QuizId == 0;
}

<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

@if (!hasSubjects)
{
    <div class="alert alert-warning">
        <strong>No subjects found.</strong>
        <a asp-controller="Subject" asp-action="Create" class="alert-link">Create a subject</a>
        first, then add
        <a asp-controller="Question" asp-action="Create" class="alert-link">questions</a>
        before creating a quiz.
    </div>
}

<div class="row g-4">
    <div class="col-12">
        <div class="card shadow-sm quiz-form-card">
            <div class="card-body p-4">
                <div class="quiz-wizard-panel active" data-panel="1">
                    <h4 class="mb-3">Basic Information</h4>
                    <p class="text-muted mb-4">Choose where this quiz belongs and give it a title.</p>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Quiz Title</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Midterm Physics Quiz" maxlength="200" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SubjectId" class="form-label fw-semibold">Subject</label>
                        <select name="SubjectId" id="SubjectId" class="form-select" required>
                            @foreach (var item in Model.Subjects)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="SubjectId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TopicId" class="form-label fw-semibold">Topic <span class="text-muted fw-normal">(optional)</span></label>
                        <select name="TopicId" id="TopicId" class="form-select">
                            @foreach (var item in Model.Topics)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                        <div class="form-text">Topics load based on the selected subject.</div>
                    </div>
                </div>

                <div class="quiz-wizard-panel" data-panel="2">
                    <h4 class="mb-3">Quiz Settings &amp; Filters</h4>
                    <p class="text-muted mb-4">
                        Set how many questions to draw randomly from the bank. Questions are generated automatically — you do not pick them manually.
                    </p>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NoOfQuestions" class="form-label fw-semibold">Number of Questions</label>
                            <input asp-for="NoOfQuestions" type="number" min="1" max="200" class="form-control" id="NoOfQuestions" required />
                            <span asp-validation-for="NoOfQuestions" class="text-danger"></span>
                            <div class="form-text">This many questions will be randomly selected each time you generate.</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TotalMarks" class="form-label fw-semibold">Total Marks</label>
                            <input asp-for="TotalMarks" type="number" min="1" max="1000" class="form-control" id="TotalMarks" required />
                            <span asp-validation-for="TotalMarks" class="text-danger"></span>
                        </div>

                        @if (isCreate)
                        {
                            <div class="col-md-6">
                                <label asp-for="ArrangementCount" class="form-label fw-semibold">Number of Arrangements</label>
                                <input asp-for="ArrangementCount" type="number" min="1" max="20" class="form-control" id="ArrangementCount" required />
                                <span asp-validation-for="ArrangementCount" class="text-danger"></span>
                                <div class="form-text">
                                    One random question set is drawn. Extra arrangements (same questions, different order) stay under this quiz — they are not added as separate rows in the quiz list.
                                </div>
                            </div>
                        }

                        <div class="col-md-6">
                            <label asp-for="TimeLimitMinutes" class="form-label fw-semibold">Time Limit (minutes)</label>
                            <select asp-for="TimeLimitMinutes" class="form-select" id="TimeLimitMinutes">
                                <option value="1">1 minute</option>
                                <option value="2">2 minutes</option>
                                <option value="5">5 minutes</option>
                                <option value="10">10 minutes</option>
                                <option value="15">15 minutes</option>
                                <option value="20">20 minutes</option>
                                <option value="25">25 minutes</option>
                                <option value="30">30 minutes</option>
                                <option value="35">35 minutes</option>
                                <option value="40">40 minutes</option>
                                <option value="45">45 minutes</option>
                                <option value="50">50 minutes</option>
                                <option value="55">55 minutes</option>
                                <option value="60">60 minutes</option>    
                            </select>
                        </div>

                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" id="IsActive" />
                                <label asp-for="IsActive" class="form-check-label fw-semibold">Quiz is active</label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DifficultyFilter" class="form-label fw-semibold">Difficulty Filter</label>
                            <select asp-for="DifficultyFilter" class="form-select" id="DifficultyFilter">
                                <option value="">Any difficulty</option>
                                <option value="0">Easy</option>
                                <option value="1">Medium</option>
                                <option value="2">Hard</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="QuestionTypeFilter" class="form-label fw-semibold">Question Type Filter</label>
                            <select asp-for="QuestionTypeFilter" class="form-select" id="QuestionTypeFilter">
                                <option value="">Any type</option>
                                <option value="1">Single Correct</option>
                                <option value="0">Multiple Correct</option>
                            </select>
                        </div>
                    </div>

                    <div class="alert alert-info mt-4 mb-0" id="questionBankInfo">
                        <span id="availableQuestionText">Select a subject to see how many questions are available for random generation.</span>
                    </div>
                </div>

                <div class="quiz-wizard-panel" data-panel="3">
                    <h4 class="mb-3">Review &amp; Save</h4>
                    <p class="text-muted mb-4">
                        On save, the app randomly picks questions from the bank using your filters and question count.
                        @if (isCreate)
                        {
                            <text>If arrangements &gt; 1, extra sets are kept under this quiz (not shown separately in the quiz list).</text>
                        }
                        You can regenerate a new random set anytime from the Generated Questions page.
                    </p>

                    <div class="review-grid">
                        <div><strong>Title</strong><span id="reviewTitle">-</span></div>
                        <div><strong>Subject</strong><span id="reviewSubject">-</span></div>
                        <div><strong>Topic</strong><span id="reviewTopic">Any</span></div>
                        <div><strong>Questions to draw</strong><span id="reviewQuestions">-</span></div>
                        @if (isCreate)
                        {
                        <div><strong>Arrangements</strong><span id="reviewArrangements">1</span></div>
                        }
                        <div><strong>Available in bank</strong><span id="reviewAvailable">-</span></div>
                        <div><strong>Total Marks</strong><span id="reviewMarks">-</span></div>
                        <div><strong>Time Limit</strong><span id="reviewTime">-</span></div>
                        <div><strong>Difficulty</strong><span id="reviewDifficulty">Any</span></div>
                        <div><strong>Question Type</strong><span id="reviewType">Any</span></div>
                        <div><strong>Status</strong><span id="reviewStatus">Active</span></div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                    <button type="button" class="btn btn-outline-secondary" id="prevStepBtn" style="visibility:hidden;">Back</button>
                    <div>
                        <button type="button" class="btn btn-primary" id="nextStepBtn">Next</button>
                        <button type="submit" class="btn btn-success d-none" id="submitQuizBtn" disabled="@(!hasSubjects)">Save &amp; Generate Quiz</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@model quizportal.Models.QuizInfo

@{
    ViewData["Title"] = "Quiz Details";
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3>Quiz Details</h3>
        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <tr>
                    <th width="35%">Quiz ID</th>
                    <td>@Model.QuizID</td>
                </tr>

                <tr>
                    <th>Quiz Title</th>
                    <td>@Model.Title</td>
                </tr>

                <tr>
                    <th>Number of Questions</th>
                    <td>@Model.NoOfQuestions</td>
                </tr>

                <tr>
                    <th>Total Marks</th>
                    <td>@Model.TotalMarks</td>
                </tr>

                <tr>
                    <th>Time Limit</th>
                    <td>@Model.TimeLimit Minutes</td>
                </tr>

            </table>

            <div class="mt-3">
                <a href="/Quiz/QuizList" class="btn btn-secondary">Back</a>
            </div>

        </div>

    </div>

</div>
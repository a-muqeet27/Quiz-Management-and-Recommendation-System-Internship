@model quizportal.Models.QuizInfo

@{
    ViewData["Title"] = "Edit Quiz";
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-warning">
            <h3>Edit Quiz</h3>
        </div>


        <div class="card-body">

            <form asp-controller="Quiz" asp-action="Edit" method="post">

                <input type="hidden" name="QuizID" value="@Model.QuizID" />

                <div class="mb-3">
                    <label>Quiz Title</label>
                    <input type="text" name="Title" value="@Model.Title" class="form-control" required />
                </div>


                <div class="mb-3">
                    <label>Number of Questions</label>
                    <input type="number" name="NoOfQuestions" value="@Model.NoOfQuestions" class="form-control" min="1" required />
                </div>


                <div class="mb-3">
                    <label>Total Marks</label>
                    <input type="number" name="TotalMarks" value="@Model.TotalMarks" class="form-control" min="1" required />
                </div>


                <div class="mb-3">
                    <label>Time Limit</label>
                    <select name="TimeLimit" class="form-select">
                        <option value="5" selected="@(Model.TimeLimit == 5)">5 Minutes</option>
                        <option value="10" selected="@(Model.TimeLimit == 10)">10 Minutes</option>
                        <option value="15" selected="@(Model.TimeLimit == 15)">15 Minutes</option>
                        <option value="20" selected="@(Model.TimeLimit == 20)">20 Minutes</option>
                        <option value="30" selected="@(Model.TimeLimit == 30)">30 Minutes</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-success">Save Changes</button>
                <a href="/Quiz/QuizList" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
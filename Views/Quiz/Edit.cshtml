@model quizportal.Models.ViewModels.QuizFormViewModel
@{
    ViewData["Title"] = "Edit Quiz";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Edit Quiz</h2>
            <p class="text-muted mb-0">Update quiz details for <strong>@Model.Title</strong></p>
        </div>
        <a asp-action="QuizList" class="btn btn-outline-secondary">Back to List</a>
    </div>

    <form asp-action="Edit" method="post" id="quizForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="QuizId" />
        <partial name="_QuizFormFields" model="Model" />
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/quiz-form.js" asp-append-version="true"></script>
}

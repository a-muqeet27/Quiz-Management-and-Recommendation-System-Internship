@model IEnumerable<quizportal.Models.Quiz>
@{
    ViewData["Title"] = "Quizzes";
    var subjects = ViewBag.Subjects as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<div class="container mt-4 mb-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="mb-1">Quizzes</h2>
        </div>
        <a asp-action="Create" class="btn btn-primary">+ Create Quiz</a>
    </div>

    <form method="get" asp-action="QuizList" class="row g-2 align-items-end mb-4">
        <div class="col-md-5">
            <label class="form-label fw-semibold">Filter by Subject</label>
            <select name="subjectId" class="form-select" onchange="this.form.submit()">
                @foreach (var item in subjects)
                {
                    if (item.Selected)
                    {
                        <option value="@item.Value" selected>@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-auto">
            <a asp-action="QuizList" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="card shadow-sm text-center p-5">
            <h4>No quizzes yet</h4>
            <p class="text-muted">Create subjects and questions first, then build your first quiz.</p>
            <a asp-action="Create" class="btn btn-primary">Create Quiz</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Subject</th>
                        <th>Topic</th>
                        <th>Questions</th>
                        <th>Sets</th>
                        <th>Generated</th>
                        <th>Marks</th>
                        <th>Time</th>
                        <th>Status</th>
                        <th width="300">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var quiz in Model)
                    {
                        <tr>
                            <td>@quiz.QuizId</td>
                            <td class="text-start"><strong>@quiz.Title</strong></td>
                            <td>@(quiz.Subject?.SubjectName ?? "-")</td>
                            <td>@(quiz.Topic?.TopicName ?? "Any")</td>
                            <td>@quiz.NoOfQuestions</td>
                            <td>@(1 + quiz.ArrangementQuizzes.Count)</td>
                            <td>@quiz.QuizQuestions.Count</td>
                            <td>@quiz.TotalMarks</td>
                            <td>@quiz.TimeLimitMinutes min</td>
                            <td>
                                <span class="badge @(quiz.IsActive ? "bg-success" : "bg-secondary")">
                                    @(quiz.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <a asp-action="GeneratedQuestions" asp-route-id="@quiz.QuizId" class="btn btn-primary btn-sm">Questions</a>
                                <a asp-action="Details" asp-route-id="@quiz.QuizId" class="btn btn-info btn-sm">Details</a>
                                <a asp-action="Edit" asp-route-id="@quiz.QuizId" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@quiz.QuizId" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

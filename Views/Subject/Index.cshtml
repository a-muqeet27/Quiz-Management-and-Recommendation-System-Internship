@model IEnumerable<quizportal.Models.Subject>
@{
    ViewData["Title"] = "Subjects";
}

<div class="container mt-4 mb-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Subjects</h2>
            <p class="text-muted mb-0">Manage subjects used by quizzes and topics</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">+ Create Subject</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm text-center p-5">
            <h4>No subjects yet</h4>
            <p class="text-muted">Create a subject first, then add topics for it.</p>
            <a asp-action="Create" class="btn btn-primary">Create Subject</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Topics</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th width="260">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var subject in Model)
                    {
                        <tr>
                            <td>@subject.SubjectId</td>
                            <td class="text-start"><strong>@subject.SubjectName</strong></td>
                            <td class="text-start">@(subject.SubjectDescription ?? "-")</td>
                            <td>@subject.Topics.Count</td>
                            <td>
                                <span class="badge @(subject.IsActive ? "bg-success" : "bg-secondary")">
                                    @(subject.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>@subject.CreatedDate.ToLocalTime().ToString("g")</td>
                            <td>
                                <a asp-controller="Topic" asp-action="Create" asp-route-subjectId="@subject.SubjectId" class="btn btn-outline-primary btn-sm">+ Topic</a>
                                <a asp-action="Edit" asp-route-id="@subject.SubjectId" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@subject.SubjectId" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@model quizportal.Models.Subject
@{
    ViewData["Title"] = "Delete Subject";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">Delete Subject</h3>
                </div>
                <div class="card-body p-4">
                    <p class="fs-5">Are you sure you want to delete this subject?</p>

                    <div class="bg-light rounded p-3 mb-4">
                        <p class="mb-1"><strong>Name:</strong> @Model.SubjectName</p>
                        <p class="mb-1"><strong>Description:</strong> @(Model.SubjectDescription ?? "-")</p>
                        <p class="mb-0"><strong>Topics:</strong> @Model.Topics.Count</p>
                    </div>

                    @if (Model.Topics.Any())
                    {
                        <div class="alert alert-warning">
                            This subject has @Model.Topics.Count topic(s). Delete those topics first, or the delete will be blocked.
                        </div>
                    }

                    <form asp-action="Delete" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.SubjectId" />
                        <button type="submit" class="btn btn-danger">Delete</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

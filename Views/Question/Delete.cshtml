@model quizportal.Models.Question
@{
    ViewData["Title"] = "Delete Question";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">Delete Question</h3>
                </div>
                <div class="card-body p-4">
                    <p class="fs-5">Are you sure you want to delete this question?</p>

                    <div class="bg-light rounded p-3 mb-4">
                        <p class="mb-1"><strong>Question:</strong> @Model.QuestionStatement</p>
                        <p class="mb-1"><strong>Subject:</strong> @(Model.Subject?.SubjectName ?? "-")</p>
                        <p class="mb-0"><strong>Choices:</strong> @Model.Choices.Count</p>
                    </div>

                    <form asp-action="Delete" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.QuestionId" />
                        <button type="submit" class="btn btn-danger">Delete</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@model quizportal.Models.ViewModels.QuestionFormViewModel
@{
    ViewData["Title"] = "Create Question";
    var hasSubjects = ViewBag.HasSubjects as bool? ?? false;
}

<div class="container mt-4 mb-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span>@TempData["SuccessMessage"]</span>
                <div class="d-flex gap-2 align-items-center">
                    <a href="#createForm" class="btn btn-sm btn-success">Add More Question</a>
                    <a asp-action="Index" class="btn btn-sm btn-outline-success">View Questions</a>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Create Question</h2>
            <p class="text-muted mb-0">Add a question with subject, topic, and answer choices</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

    <div id="createForm">
        <form asp-action="Create" method="post" id="questionForm">
            @Html.AntiForgeryToken()
            <partial name="_QuestionFormFields" model="Model" />

            <div class="d-flex gap-2 mt-4 flex-wrap">
                <button type="submit" class="btn btn-primary" disabled="@(!hasSubjects)">Save Question</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/question-form.js" asp-append-version="true"></script>
}
